rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        ('email' in request.auth.token && request.auth.token.email == 'yomz84.dm@gmail.com') ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      ); 
    }

    match /handymen/{handymanId} {
      allow read: if true;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if (isSignedIn() && existing().userId == request.auth.uid && incoming().userId == existing().userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (userId == request.auth.uid || isAdmin());
      // Handymen might need to read user profiles to get info, so we allow reads
      // Better: if true, but ideally restricted.
      allow create: if isSignedIn() && request.auth.uid == userId && incoming().uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId && incoming().uid == existing().uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /jobRequests/{jobId} {
      allow read: if isSignedIn() && (existing().userUid == request.auth.uid || existing().proUserId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userUid == request.auth.uid;
      allow update: if isSignedIn() && (
        (existing().userUid == request.auth.uid && incoming().userUid == existing().userUid) || 
        (existing().proUserId == request.auth.uid && incoming().proUserId == existing().proUserId) || 
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /disputes/{disputeId} {
      allow read: if isAdmin() || (isSignedIn() && existing().raisedBy == request.auth.uid);
      allow create: if isSignedIn() && incoming().raisedBy == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /managedDomains/{domainId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      allow create: if isSignedIn(); // allow system or users to create
      allow update, delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    match /chats/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in existing().participants;
      allow create: if isSignedIn() && request.auth.uid in incoming().participants;
      allow update: if isSignedIn() && request.auth.uid in existing().participants && incoming().participants == existing().participants;
      allow delete: if isAdmin();
      
      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants && incoming().senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    match /test/connection {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
