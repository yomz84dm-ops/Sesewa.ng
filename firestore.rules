rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net (Deny by default)
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/(default)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email == 'yomz84.dm@gmail.com' && request.auth.token.email_verified == true)
      );
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdminEmail(email) {
      return email == 'yomz84.dm@gmail.com';
    }

    // --- User Validation ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 200 &&
             data.role in ['user', 'handyman', 'admin'] &&
             (data.role != 'admin' || isAdminEmail(data.email)) &&
             (!('credits' in data) || data.credits is number) &&
             (!('plan' in data) || data.plan in ['basic', 'pro', 'member']);
    }

    function isValidHandyman(data) {
      return data.keys().hasAll(['userId', 'name', 'category', 'location', 'rating']) &&
             data.userId == request.auth.uid &&
             data.rating >= 0 && data.rating <= 5;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      // Relaxed creation slightly to ensure sign-in/signup flow isn't blocked by missing optional fields
      allow create: if isOwner(userId) && incoming().uid == userId;
      allow update: if isOwner(userId) && (
        // Action: Update Profile (restricted fields)
        (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'photoURL', 'phone', 'lat', 'lng', 'isVerifiedPending', 'idDocumentUrl']))
      ) || isAdmin();
    }

    match /handymen/{handymanId} {
      // FIX: Allow public read to solve "Missing or insufficient permissions" in feed and connection test
      allow read: if true; 
      
      // Ensure create matches the schema used in your frontend
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      
      allow update: if isSignedIn() && (
        (isOwner(existing().userId) && 
         !incoming().diff(existing()).affectedKeys().intersection(['rating', 'reviews', 'verified', 'isFeatured']).size() > 0
        ) || isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /jobRequests/{requestId} {
      allow get, list: if isSignedIn() && (
        isOwner(resource.data.userUid) || 
        isOwner(resource.data.proUserId) || 
        isAdmin()
      );
      allow create: if isSignedIn() && incoming().userUid == request.auth.uid;
      allow update: if isSignedIn() && (
        isOwner(existing().userUid) || 
        isOwner(existing().proUserId) || 
        isAdmin()
      );
    }

    match /test/connection {
      allow read, get, list: if true;
    }

    match /chats/{chatId} {
      allow get: if isSignedIn() && request.auth.uid in existing().participants;
      allow list: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() && request.auth.uid in incoming().participants;
      allow update: if isSignedIn() && request.auth.uid in existing().participants;

      match /messages/{messageId} {
        allow get, list: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isSignedIn() && 
          request.auth.uid == incoming().senderId &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    match /notifications/{notificationId} {
      allow get: if isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && (
        isOwner(incoming().userId) || 
        isAdmin()
      );
      allow update: if isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isOwner(existing().userId);
    }

    match /disputes/{disputeId} {
      allow read: if isSignedIn() && (isOwner(existing().raisedBy) || isAdmin());
      allow create: if isSignedIn() && incoming().raisedBy == request.auth.uid;
      allow update: if isAdmin();
    }

    match /managedDomains/{domainId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /admins/{adminId} {
      allow get: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
      allow list: if isAdmin();
      allow write: if false; 
    }

    match /reviews/{reviewId} {
      allow read: if true; // Public reviews
      allow create: if isSignedIn() && 
        incoming().rating >= 1 && 
        incoming().rating <= 5 &&
        incoming().comment is string;
      allow update, delete: if isAdmin();
    }
  }
}
