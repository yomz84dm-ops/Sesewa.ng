rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'yomz84.dm@gmail.com'
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdminEmail(email) {
      return email == 'yomz84.dm@gmail.com';
    }

    // --- User Validation ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 200 &&
             data.role in ['user', 'handyman', 'admin'] &&
             (data.role != 'admin' || isAdminEmail(data.email)) &&
             (!('credits' in data) || data.credits is number) &&
             (!('plan' in data) || data.plan in ['basic', 'pro', 'member']);
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().uid == userId;
      allow update: if (isOwner(userId) && (
        // Action: Update Profile (not role, verified, or credits)
        (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'photoURL', 'phone', 'lat', 'lng', 'isVerifiedPending', 'idDocumentUrl'])) ||
        // Action: Handyman Upgrade (initial)
        (incoming().diff(existing()).affectedKeys().hasOnly(['role', 'plan', 'credits']) && existing().role == 'user' && incoming().role == 'handyman')
      )) || isAdmin();
    }

    match /handymen/{handymanId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(handymanId) && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && (
        (isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'category', 'location', 'phone', 'whatsapp', 'experience', 'experienceYears', 'description', 'portfolio', 'profileImage', 'availability', 'isOnline'])) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // --- Job Request Validation ---
    function isValidJobRequest(data) {
      return data.keys().hasAll(['id', 'proId', 'userUid', 'status']) &&
             isValidId(data.id) &&
             isValidId(data.proId) &&
             data.userUid == request.auth.uid &&
             data.status in ['pending', 'responded', 'on-the-way', 'completed', 'cancelled'] &&
             (!('amount' in data) || data.amount is number) &&
             (!('unlockedBy' in data) || (data.unlockedBy is list && data.unlockedBy.size() <= 50));
    }

    function isTerminal(data) {
      return data.status == 'completed' || data.status == 'cancelled';
    }

    match /jobRequests/{requestId} {
      allow read: if isSignedIn() && (
        isOwner(existing().userUid) || 
        isOwner(existing().proUserId) || 
        (isSignedIn() && request.auth.uid in existing().get('unlockedBy', [])) ||
        isAdmin()
      );
      allow create: if isSignedIn() && isValidJobRequest(incoming());
      allow update: if isSignedIn() && (
        isAdmin() || (
          !isTerminal(existing()) && (
            (isOwner(existing().userUid) && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'jobDescription', 'amount', 'paystackReference'])) ||
            (isOwner(existing().proUserId) && incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
            // Action: Unlock Lead
            (incoming().diff(existing()).affectedKeys().hasOnly(['unlockedBy']) && 
             incoming().unlockedBy.size() == existing().get('unlockedBy', []).size() + 1 &&
             incoming().unlockedBy.hasAll(existing().get('unlockedBy', [])) &&
             request.auth.uid in incoming().unlockedBy)
          )
        )
      );
    }

    match /test/connection {
      allow read: if true;
    }

    match /chats/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in existing().participants;
      allow create: if isSignedIn() && request.auth.uid in incoming().participants;
      allow update: if isSignedIn() && request.auth.uid in existing().participants;

      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isSignedIn() && 
          request.auth.uid == incoming().senderId &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    match /notifications/{notificationId} {
      allow get: if isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && (incoming().userId == request.auth.uid || isAdmin());
      allow update: if isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isOwner(existing().userId);
    }

    match /disputes/{disputeId} {
      allow read: if isSignedIn() && (isOwner(existing().raisedBy) || isAdmin());
      allow create: if isSignedIn() && incoming().raisedBy == request.auth.uid;
      allow update: if isAdmin();
    }

    match /managedDomains/{domainId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable through Firebase Console or initial script
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
  }
}
