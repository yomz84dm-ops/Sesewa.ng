rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        ('email' in request.auth.token && request.auth.token.email == 'yomz84.dm@gmail.com') ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      ); 
    }

    match /handymen/{handymanId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if isSignedIn() && (request.resource.data.userId == request.auth.uid || resource.data.userId == request.auth.uid || isAdmin());
    }

    match /jobRequests/{jobId} {
      allow read: if isSignedIn() && (resource.data.userUid == request.auth.uid || resource.data.proUserId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userUid == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.userUid == request.auth.uid || resource.data.proUserId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /disputes/{disputeId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.raisedBy == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.raisedBy == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /managedDomains/{domainId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow write: if isSignedIn();
    }

    match /chats/{chatId} {
      allow read, update: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;
      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants && request.resource.data.senderId == request.auth.uid;
      }
    }

    match /test/connection {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
