rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'yomz84.dm@gmail.com'
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdminEmail(email) {
      return email == 'yomz84.dm@gmail.com';
    }

    // --- User Validation ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 200 &&
             data.role in ['user', 'handyman', 'admin'] &&
             (data.role != 'admin' || isAdminEmail(data.email)) &&
             (!('credits' in data) || data.credits is number) &&
             (!('plan' in data) || data.plan in ['basic', 'pro', 'member']);
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().uid == userId;
      allow update: if isOwner(userId) && (
        // Action: Update Profile (not role)
        (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'photoURL', 'phone', 'lat', 'lng', 'isVerifiedPending', 'idDocumentUrl', 'verified'])) ||
        // Action: Handyman Upgrade
        (incoming().diff(existing()).affectedKeys().hasOnly(['role', 'plan', 'credits']) && incoming().role == 'handyman')
      ) || isAdmin();
    }

    match /handymen/{handymanId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && isValidId(handymanId);
      allow update: if isSignedIn() && (
        isOwner(existing().userId) || isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /jobRequests/{requestId} {
      allow get, list: if isSignedIn() && (
        isOwner(resource.data.userUid) || 
        isOwner(resource.data.proUserId) || 
        isAdmin()
      );
      allow create: if isSignedIn() && incoming().userUid == request.auth.uid;
      allow update: if isSignedIn() && (
        isOwner(existing().userUid) || 
        isOwner(existing().proUserId) || 
        isAdmin()
      );
    }

    match /test/connection {
      allow get: if true;
    }

    match /chats/{chatId} {
      allow get: if isSignedIn() && request.auth.uid in existing().participants;
      allow list: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() && request.auth.uid in incoming().participants;
      allow update: if isSignedIn() && request.auth.uid in existing().participants;

      match /messages/{messageId} {
        allow get, list: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isSignedIn() && 
          request.auth.uid == incoming().senderId &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    match /notifications/{notificationId} {
      allow get: if isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && (incoming().userId == request.auth.uid || isAdmin());
      allow update: if isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isOwner(existing().userId);
    }

    match /disputes/{disputeId} {
      allow read: if isSignedIn() && (isOwner(existing().raisedBy) || isAdmin());
      allow create: if isSignedIn() && incoming().raisedBy == request.auth.uid;
      allow update: if isAdmin();
    }

    match /managedDomains/{domainId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /admins/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow write: if false; 
    }

    match /reviews/{reviewId} {
      allow get, list: if true;
      allow create: if isSignedIn() && incoming().userName is string; // Basic check
      allow update, delete: if isAdmin();
    }
  }
}
