{
  "entities": {
    "User": {
      "title": "User",
      "description": "Application user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "handyman", "admin"] },
        "name": { "type": "string" },
        "photoURL": { "type": "string" },
        "phone": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "credits": { "type": "number" },
        "plan": { "type": "string", "enum": ["basic", "pro", "member"] },
        "verified": { "type": "boolean" }
      },
      "required": ["uid", "email", "role"]
    },
    "Handyman": {
      "title": "Handyman",
      "description": "Professional handyman profile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "rating": { "type": "number" },
        "reviews": { "type": "number" },
        "description": { "type": "string" },
        "price": { "type": "string" },
        "location": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "image": { "type": "string" },
        "verified": { "type": "boolean" },
        "online": { "type": "boolean" },
        "experience": { "type": "number" },
        "skills": { "type": "array" }
      },
      "required": ["id", "userId", "name", "category"]
    },
    "JobRequest": {
      "title": "JobRequest",
      "description": "A request for a handyman job",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userUid": { "type": "string" },
        "proUserId": { "type": "string" },
        "category": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/handymen/{handymanId}": {
      "schema": "Handyman",
      "description": "Handyman professional profiles"
    },
    "/jobRequests/{requestId}": {
      "schema": "JobRequest",
      "description": "Job requests and bookings"
    },
    "/chats/{chatId}": {
      "schema": "object",
      "description": "Chat sessions"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "object",
      "description": "Chat messages"
    },
    "/notifications/{notificationId}": {
      "schema": "object",
      "description": "User notifications"
    }
  }
}
