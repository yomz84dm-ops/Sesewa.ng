{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "name": { "type": "string", "description": "User's full name" },
        "role": { "type": "string", "enum": ["admin", "user", "handyman"], "description": "User's role in the application" },
        "photoURL": { "type": "string", "description": "URL to the user's profile picture" },
        "phone": { "type": "string", "description": "User's phone number" },
        "plan": { "type": "string", "enum": ["basic", "pro", "member"], "description": "User's subscription plan" },
        "credits": { "type": "number", "description": "User's lead credits" },
        "isVerifiedPending": { "type": "boolean", "description": "Whether verification is pending" },
        "verified": { "type": "boolean", "description": "Whether the user is verified" },
        "idDocumentUrl": { "type": "string", "description": "URL to the uploaded ID document" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user account was created" },
        "lat": { "type": "number" },
        "lng": { "type": "number" }
      },
      "required": ["uid", "email", "role"]
    },
    "Handyman": {
      "title": "Handyman",
      "description": "Professional service provider profile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "location": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "rating": { "type": "number" },
        "reviews": { "type": "number" },
        "phone": { "type": "string" },
        "whatsapp": { "type": "string" },
        "experience": { "type": "string" },
        "experienceYears": { "type": "number" },
        "verified": { "type": "boolean" },
        "isFeatured": { "type": "boolean" },
        "isOnline": { "type": "boolean" },
        "description": { "type": "string" },
        "portfolio": { "type": "array", "items": { "type": "string" } },
        "profileImage": { "type": "string" },
        "userId": { "type": "string" },
        "availability": { "type": "string" },
        "plan": { "type": "string" },
        "ninVerified": { "type": "boolean" }
      },
      "required": ["id", "name", "category", "location", "rating"]
    },
    "JobRequest": {
      "title": "JobRequest",
      "description": "A request for a service from a user to a pro",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "proId": { "type": "string" },
        "proUserId": { "type": "string", "description": "UID of the professional" },
        "proName": { "type": "string" },
        "userUid": { "type": "string" },
        "userName": { "type": "string" },
        "userPhone": { "type": "string" },
        "jobDescription": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "responded", "on-the-way", "completed", "cancelled"] },
        "paymentStatus": { "type": "string" },
        "amount": { "type": "number" },
        "paystackReference": { "type": "string" },
        "date": { "type": "string" },
        "unlockedBy": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "proId", "userUid", "status"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A conversation between two users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "otherParticipantName": { "type": "string" }
      },
      "required": ["id", "participants", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message in a chat",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "chatId", "senderId", "text", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A system or user notification",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "relatedId": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "message", "read", "createdAt"]
    },
    "Dispute": {
      "title": "Dispute",
      "description": "A dispute raised for a job request",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "jobRequestId": { "type": "string" },
        "raisedBy": { "type": "string" },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "resolved", "refunded"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "resolvedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "jobRequestId", "raisedBy", "status", "createdAt"]
    },
    "ManagedDomain": {
      "title": "ManagedDomain",
      "description": "A domain managed by the platform",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string", "description": "Domain name, e.g., sesewa.ng" },
        "mode": { "type": "string", "enum": ["serve", "redirect"], "description": "Whether to serve traffic or redirect" },
        "target": { "type": "string", "description": "Redirect destination if mode is redirect" },
        "isDefault": { "type": "boolean", "description": "Whether this is the primary/default domain" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "mode"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/handymen/{handymanId}": {
      "schema": "Handyman",
      "description": "Professional service provider profiles"
    },
    "/jobRequests/{requestId}": {
      "schema": "JobRequest",
      "description": "Service requests"
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Chat sessions"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a chat"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    },
    "/disputes/{disputeId}": {
      "schema": "Dispute",
      "description": "Disputes for job requests"
    },
    "/managedDomains/{domainId}": {
      "schema": "ManagedDomain",
      "description": "Domains managed for country-specific traffic"
    }
  }
}
