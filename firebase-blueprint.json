{
  "entities": {
    "Handyman": {
      "title": "Handyman",
      "description": "Professional handyman profile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "location": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "rating": { "type": "number" },
        "reviews": { "type": "number" },
        "phone": { "type": "string" },
        "whatsapp": { "type": "string" },
        "experience": { "type": "string" },
        "experienceYears": { "type": "number" },
        "verified": { "type": "boolean" },
        "isFeatured": { "type": "boolean" },
        "isOnline": { "type": "boolean" },
        "description": { "type": "string" },
        "portfolio": { "type": "array", "items": { "type": "string" } },
        "profileImage": { "type": "string" },
        "userId": { "type": "string" },
        "availability": { "type": "string" },
        "plan": { "type": "string" },
        "ninVerified": { "type": "boolean" }
      },
      "required": ["id", "name", "category", "userId"]
    },
    "AppUser": {
      "title": "User",
      "description": "Application user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "handyman", "admin"] },
        "photoURL": { "type": "string" },
        "phone": { "type": "string" },
        "plan": { "type": "string", "enum": ["basic", "pro", "member"] },
        "credits": { "type": "number" },
        "isVerifiedPending": { "type": "boolean" },
        "verified": { "type": "boolean" },
        "idDocumentUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lat": { "type": "number" },
        "lng": { "type": "number" }
      },
      "required": ["uid", "email"]
    },
    "JobRequest": {
      "title": "Job Request",
      "description": "A job request sent from a user to a handyman",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "proId": { "type": "string" },
        "proUserId": { "type": "string" },
        "proName": { "type": "string" },
        "userUid": { "type": "string" },
        "userName": { "type": "string" },
        "userPhone": { "type": "string" },
        "jobDescription": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "responded", "on-the-way", "completed", "cancelled"] },
        "paymentStatus": { "type": "string", "enum": ["none", "pending", "escrowed", "released", "refunded", "disputed"] },
        "amount": { "type": "number" },
        "paystackReference": { "type": "string" },
        "date": { "type": "string" },
        "unlockedBy": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "proId", "userUid"]
    },
    "Dispute": {
      "title": "Dispute",
      "description": "A dispute raised for a job request",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "jobRequestId": { "type": "string" },
        "raisedBy": { "type": "string" },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "resolved", "refunded"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "resolvedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "jobRequestId", "raisedBy"]
    },
    "ManagedDomain": {
      "title": "Managed Domain",
      "description": "Domain configuration for the platform",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "mode": { "type": "string", "enum": ["serve", "redirect"] },
        "target": { "type": "string" },
        "isDefault": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notification",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["message", "job_status", "quote", "system"] },
        "relatedId": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "message"]
    },
    "Chat": {
      "title": "Chat",
      "description": "One-on-one chat conversation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "participants"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message within a chat",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "chatId", "senderId", "text"]
    }
  },
  "firestore": {
    "handymen/{handymanId}": {
      "schema": "Handyman",
      "description": "Public directory of handymen"
    },
    "users/{userId}": {
      "schema": "AppUser",
      "description": "User account data"
    },
    "jobRequests/{requestId}": {
      "schema": "JobRequest",
      "description": "Lead and job management"
    },
    "disputes/{disputeId}": {
      "schema": "Dispute",
      "description": "Dispute handling"
    },
    "managedDomains/{domainId}": {
      "schema": "ManagedDomain",
      "description": "Domain routing"
    },
    "notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User alerts"
    },
    "chats/{chatId}": {
      "schema": "Chat",
      "description": "Conversations"
    },
    "chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Individual messages"
    },
    "test/connection": {
      "schema": { "type": "object", "properties": {} },
      "description": "Health check document"
    }
  }
}
