# ------------------------------------------------------------------------------
# API KEYS & SECRETS
# ------------------------------------------------------------------------------

# Gemini AI API Key (Get from: https://aistudio.google.com/app/apikey)
# Essential for HandyPadi chat and smart features
GEMINI_API_KEY=

# Paystack Secret Key (Get from: https://dashboard.paystack.com/#/settings/developer)
# Essential for processing payments securely on the server
PAYSTACK_SECRET_KEY=

# Paystack Public Key
# Essential for initializing the Paystack popup in the browser
VITE_PAYSTACK_PUBLIC_KEY=

# ------------------------------------------------------------------------------
# FIREBASE CONFIGURATION (Vite Client-side)
# ------------------------------------------------------------------------------
# These are used as fallbacks if firebase-applet-config.json is missing.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIRESTORE_DATABASE_ID=

# ------------------------------------------------------------------------------
# DEPLOYMENT NOTES (sesewa.ng / Firebase Hosting)
# ------------------------------------------------------------------------------
# 1. Add your custom domains (sesewa.ng, etc.) to the "Authorized Domains" 
#    list in the Firebase Console under Auth -> Settings.
# 2. Set GEMINI_API_KEY and PAYSTACK_SECRET_KEY in your Firebase Functions 
#    environment using:
#    firebase functions:secrets:set GEMINI_API_KEY
#    firebase functions:secrets:set PAYSTACK_SECRET_KEY
# ------------------------------------------------------------------------------
